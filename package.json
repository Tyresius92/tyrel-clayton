{
  "name": "learn-starter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "node_modules/.bin/eslint --color --ext js,jsx './'",
    "lintify": "node_modules/.bin/eslint --color --fix --ext js,jsx ./",
    "checkPrettier": "prettier --config .prettierrc.json --ignore-path .prettierignore --check \"./**/*.js\"",
    "prettify": "prettier --config .prettierrc.json --ignore-path .prettierignore --write \"./**/*.js\"",
    "smellsGood": "node scripts/echo \"Great success!! Your code smells goooood!\" --font-color 92",
    "sniff": "npm run checkPrettier && npm run lint && npm run smellsGood",
    "nbp": "node scripts/newBlogPost"
  },
  "dependencies": {
    "date-fns": "^2.21.1",
    "gray-matter": "^4.0.3",
    "next": "^10.0.0",
    "react": "17.0.1",
    "react-dom": "17.0.1",
    "remark": "^13.0.0",
    "remark-gfm": "^1.0.0",
    "remark-html": "^13.0.1"
  },
  "devDependencies": {
    "eslint": "^7.25.0",
    "eslint-config-standard": "^16.0.2",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^4.3.1",
    "eslint-plugin-react": "^7.23.2",
    "prettier": "^2.2.1"
  }
}
